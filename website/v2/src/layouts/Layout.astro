---
export interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Sequential Analytics — Quietly Powerful Website Analytics',
  description = 'Sequential is a privacy-first analytics platform for teams who want clear answers, fast setup, and no cookie-banner drama.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Onest:wght@300;400;500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <slot name="head" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #1b211c;
    --bg-soft: #222a24;
    --bg-elevated: #2a322c;
    --bg-strong: #121713;
    --line: rgba(233, 239, 230, 0.1);
    --line-strong: rgba(233, 239, 230, 0.18);
    --text: #f2f4ed;
    --muted: #c3cabb;
    --muted-soft: #95a08f;
    --accent: #b8a4ff;
    --accent-strong: #cabdff;
    --accent-deep: #4c4566;
    --accent-wash: rgba(184, 164, 255, 0.15);
    --success: #9ad8ae;
    --shadow-lg: 0 32px 80px rgba(0, 0, 0, 0.28);
    --shadow-md: 0 18px 40px rgba(0, 0, 0, 0.2);
    --radius-sm: 12px;
    --radius-md: 20px;
    --radius-lg: 28px;
    --radius-xl: 36px;
    --content: 1180px;
    --font-sans: 'Onest', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
  }

  body {
    min-width: 320px;
    font-family: var(--font-sans);
    background:
      radial-gradient(circle at top left, rgba(184, 164, 255, 0.1), transparent 28%),
      radial-gradient(circle at 85% 10%, rgba(184, 164, 255, 0.08), transparent 18%),
      linear-gradient(180deg, #1d241e 0%, #1a1f1b 40%, #171c18 100%);
    color: var(--text);
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.07;
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
    background-size: 72px 72px;
    mask-image: radial-gradient(circle at center, black 36%, transparent 100%);
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  button,
  input,
  textarea,
  select {
    font: inherit;
  }

  ::selection {
    background: rgba(184, 164, 255, 0.28);
    color: var(--text);
  }

  .container {
    width: min(var(--content), calc(100vw - 2rem));
    margin: 0 auto;
  }

  .section-kicker {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.4rem 0.72rem;
    border: 1px solid var(--line);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.02);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .section-kicker::before {
    content: '';
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 999px;
    background: var(--accent);
    box-shadow: 0 0 20px rgba(184, 164, 255, 0.85);
  }

  .section-heading {
    max-width: 14ch;
    font-size: clamp(2.1rem, 6vw, 4.4rem);
    line-height: 0.98;
    letter-spacing: -0.055em;
  }

  .section-copy {
    max-width: 42rem;
    color: var(--muted);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
  }

  @media (max-width: 720px) {
    .container {
      width: min(var(--content), calc(100vw - 1.25rem));
    }
  }
</style>
