---
import Layout from '../layouts/Layout.astro';

const featureCards = [
  {
    title: 'Privacy stays default',
    copy:
      'No cookies, no creepy profiling, no banner fatigue. Sequential gives you the signal without making your visitors pay for it.',
  },
  {
    title: 'A script measured in kilobytes',
    copy:
      'Lightweight enough to disappear into your stack, fast enough to keep Core Web Vitals where they should be.',
  },
  {
    title: 'One dashboard that explains itself',
    copy:
      'Readable metrics, live traffic, top pages, and campaign context in one place. No certification exam required.',
  },
];

const journey = [
  ['01', 'Create your site', 'Spin up a property, invite your team, and grab a single snippet.'],
  ['02', 'Drop in the script', 'Works with Astro, Next.js, WordPress, Shopify, and whatever else your team ships.'],
  ['03', 'Watch the story unfold', 'Realtime visitors, clean referrers, better decisions, zero analytics dread.'],
];

const testimonials = [
  {
    quote:
      'Sequential took us from “we should probably check analytics” to actually checking it every morning.',
    name: 'Dina Park',
    role: 'Growth Lead, Northstar Studio',
  },
  {
    quote:
      'The dashboard feels like a product designer finally sat with an analyst and asked what matters.',
    name: 'Marcus Ibarra',
    role: 'Founder, Draftlane',
  },
  {
    quote:
      'We migrated from GA4 in an afternoon. The big surprise was how much calmer our reporting process became.',
    name: 'Anika Bose',
    role: 'Marketing Director, Halden',
  },
];
---

<Layout>
  <main class="page-shell">
    <section class="hero">
      <div class="container">
        <header class="topbar">
          <a href="/" class="brand" aria-label="Sequential home">
            <span class="brand-mark">S/</span>
            <span class="brand-text">Sequential</span>
          </a>

          <nav class="topnav" aria-label="Primary">
            <a href="#product">Product</a>
            <a href="#why">Why Sequential</a>
            <a href="#features">Features</a>
            <a href="#customers">Customers</a>
          </nav>

          <div class="topbar-actions">
            <a href="/login" class="btn btn-quiet">Login</a>
            <a href="/signup" class="btn btn-solid">Start free trial</a>
          </div>
        </header>

        <div class="hero-grid">
          <div class="hero-copy">
            <span class="section-kicker">Independent analytics for modern teams</span>
            <h1>
              A calmer Google Analytics alternative for teams that want clarity,
              not clutter.
            </h1>
            <p class="hero-lead">
              Sequential turns website analytics into something people actually
              use: simple dashboards, privacy-first defaults, realtime insight,
              and a setup flow that takes minutes instead of meetings.
            </p>

            <div class="hero-actions">
              <a href="/signup" class="btn btn-solid btn-large">Start free trial</a>
              <a href="/demo" class="btn btn-outline btn-large">View live demo</a>
            </div>

            <div class="hero-meta">
              <span>Quick setup</span>
              <span>30-day trial</span>
              <span>No credit card</span>
            </div>
          </div>

          <div class="hero-visual" aria-hidden="true">
            <div class="floating-tag floating-tag-left">cookie-free</div>
            <div class="floating-tag floating-tag-right">realtime</div>

            <div class="dashboard-card">
              <div class="dash-window">
                <div class="dash-chrome">
                  <div class="dash-dots">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                  <span class="dash-path">app.sequential.io / hilarioustype.com</span>
                </div>

                <div class="dash-body">
                  <div class="dash-summary">
                    <div>
                      <p class="mini-label">Live people</p>
                      <strong>46</strong>
                    </div>
                    <div>
                      <p class="mini-label">Views</p>
                      <strong>98.4k</strong>
                    </div>
                    <div>
                      <p class="mini-label">Bounce rate</p>
                      <strong>31%</strong>
                    </div>
                  </div>

                  <div class="dash-chart">
                    <div class="chart-grid"></div>
                    <div class="chart-area chart-area-back"></div>
                    <div class="chart-area chart-area-front"></div>
                  </div>

                  <div class="dash-panels">
                    <div class="dash-panel">
                      <div class="panel-title">Top pages</div>
                      <div class="panel-row">
                        <span>/homepage</span>
                        <span>54.2k</span>
                      </div>
                      <div class="panel-row panel-row-active">
                        <span>/pricing</span>
                        <span>18.4k</span>
                      </div>
                      <div class="panel-row">
                        <span>/blog/privacy</span>
                        <span>8.1k</span>
                      </div>
                    </div>

                    <div class="dash-panel">
                      <div class="panel-title">Referrers</div>
                      <div class="panel-row">
                        <span>Search</span>
                        <span>43%</span>
                      </div>
                      <div class="panel-row">
                        <span>Direct</span>
                        <span>26%</span>
                      </div>
                      <div class="panel-row">
                        <span>Newsletter</span>
                        <span>12%</span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <aside class="proof-card">
                <p>
                  “Sequential gives us the right amount of information in the
                  first screen. That’s surprisingly rare.”
                </p>
                <div class="proof-person">
                  <span class="proof-avatar">LP</span>
                  <div>
                    <strong>Lena Porter</strong>
                    <span>Operations, Field Department</span>
                  </div>
                </div>
              </aside>
            </div>
          </div>
        </div>

        <div class="trust-rail">
          <p>Trusted by product teams, publishers, agencies, and privacy-conscious builders</p>
          <div class="trust-logos" aria-label="Trusted by">
            <span>GitHub</span>
            <span>Bootstrap</span>
            <span>Huberman Lab</span>
            <span>Tailwind</span>
            <span>Laravel</span>
            <span>Vercel</span>
          </div>
        </div>
      </div>
    </section>

    <section class="feature-intro" id="why">
      <div class="container intro-layout">
        <div>
          <span class="section-kicker">Why teams switch</span>
          <h2 class="section-heading">Different in the ways that matter.</h2>
        </div>
        <p class="section-copy">
          The problem with analytics is rarely a lack of data. It is the
          overhead: scripts that slow pages down, interfaces that bury answers,
          and privacy compromises nobody on your team actually wants to defend.
        </p>
      </div>

      <div class="container feature-grid" id="features">
        {featureCards.map((card, index) => (
          <article class="feature-card">
            <span class="feature-number">0{index + 1}</span>
            <h3>{card.title}</h3>
            <p>{card.copy}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="story-section" id="product">
      <div class="container story-card">
        <div class="story-copy">
          <span class="section-kicker">Inside the product</span>
          <h2 class="section-heading">One screen, fast answers, no wandering.</h2>
          <p class="section-copy">
            Sequential is built for the first five minutes after you open the
            app. Traffic, referrers, events, top pages, and live activity all
            stay within reach, with enough depth to act and none of the maze.
          </p>

          <ul class="story-list">
            <li>Realtime traffic that filters bots and junk noise.</li>
            <li>Campaign and UTM reporting without setup theater.</li>
            <li>Long-term retention so your history remains useful.</li>
          </ul>
        </div>

        <div class="story-mosaic" aria-hidden="true">
          <div class="mosaic-card card-events">
            <span class="mini-label">Events</span>
            <div class="mosaic-row">
              <span>Purchased plan</span>
              <strong>6.2%</strong>
            </div>
            <div class="mosaic-row">
              <span>Newsletter signup</span>
              <strong>24%</strong>
            </div>
            <div class="mosaic-row">
              <span>Waitlist join</span>
              <strong>11.8%</strong>
            </div>
          </div>

          <div class="mosaic-card card-metrics">
            <span class="mini-label">Realtime snapshot</span>
            <div class="metric-stack">
              <div><span>People on site</span><strong>125</strong></div>
              <div><span>Avg time on site</span><strong>03:42</strong></div>
              <div><span>Event completions</span><strong>987</strong></div>
            </div>
          </div>

          <div class="mosaic-card card-compare">
            <span class="mini-label">Setup time</span>
            <div class="compare-pill">
              <span>Sequential</span>
              <strong>6 minutes</strong>
            </div>
            <div class="compare-bar">
              <span class="compare-bar-fill"></span>
            </div>
            <p>Designed to be installed between meetings, not across a quarter.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="comparison-section">
      <div class="container comparison-shell">
        <div>
          <span class="section-kicker">A practical alternative</span>
          <h2 class="section-heading">Less ceremony. Better signal.</h2>
        </div>

        <div class="comparison-table" role="table" aria-label="Product comparison">
          <div class="comparison-head" role="row">
            <span role="columnheader">Capability</span>
            <span role="columnheader">Sequential</span>
            <span role="columnheader">Legacy analytics</span>
          </div>
          <div class="comparison-row" role="row">
            <span role="cell">Cookie banner dependency</span>
            <strong role="cell">No</strong>
            <span role="cell">Usually yes</span>
          </div>
          <div class="comparison-row" role="row">
            <span role="cell">Script weight</span>
            <strong role="cell">Tiny</strong>
            <span role="cell">Often heavy</span>
          </div>
          <div class="comparison-row" role="row">
            <span role="cell">Time to useful dashboard</span>
            <strong role="cell">Minutes</strong>
            <span role="cell">Days to weeks</span>
          </div>
          <div class="comparison-row" role="row">
            <span role="cell">Interface complexity</span>
            <strong role="cell">Low</strong>
            <span role="cell">High</span>
          </div>
        </div>
      </div>
    </section>

    <section class="steps-section">
      <div class="container steps-card">
        <div class="steps-header">
          <span class="section-kicker">Getting started</span>
          <h2 class="section-heading">Setup that feels pleasantly uneventful.</h2>
        </div>

        <div class="steps-grid">
          {journey.map(([step, title, copy]) => (
            <article class="step-card">
              <span class="step-number">{step}</span>
              <h3>{title}</h3>
              <p>{copy}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="testimonials-section" id="customers">
      <div class="container testimonials-layout">
        <div>
          <span class="section-kicker">What teams say</span>
          <h2 class="section-heading">A little less chaos goes a long way.</h2>
        </div>

        <div class="testimonials-grid">
          {testimonials.map((item) => (
            <article class="testimonial-card">
              <p class="testimonial-quote">“{item.quote}”</p>
              <div class="testimonial-person">
                <strong>{item.name}</strong>
                <span>{item.role}</span>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="cta-section">
      <div class="container cta-card">
        <div>
          <span class="section-kicker">Ready when you are</span>
          <h2>Bring clarity back to your analytics stack.</h2>
          <p>
            Start a 30-day trial, import your history if you need it, and keep
            every future visit privacy-first from day one.
          </p>
        </div>

        <div class="cta-actions">
          <a href="/signup" class="btn btn-solid btn-large">Get started</a>
          <a href="/demo" class="btn btn-outline btn-large">Live demo</a>
        </div>
      </div>
    </section>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-brand">
          <a href="/" class="brand" aria-label="Sequential home">
            <span class="brand-mark">S/</span>
            <span class="brand-text">Sequential</span>
          </a>
          <p>
            We count what matters, quietly, quickly, and without turning privacy
            into a negotiation.
          </p>
        </div>

        <div class="footer-links">
          <a href="#product">Product</a>
          <a href="#features">Features</a>
          <a href="#customers">Customers</a>
          <a href="/pricing">Pricing</a>
          <a href="/docs">Docs</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>

<style>
  .page-shell {
    position: relative;
  }

  .hero {
    padding: 1.1rem 0 3.5rem;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.95rem 0 2rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  .brand-mark {
    color: var(--text);
    font-size: 1.9rem;
    line-height: 1;
  }

  .brand-text {
    color: var(--text);
    font-size: 1.05rem;
  }

  .topnav,
  .topbar-actions,
  .hero-actions,
  .hero-meta,
  .trust-logos,
  .footer-links {
    display: flex;
    align-items: center;
  }

  .topnav {
    gap: 1.5rem;
    color: var(--muted);
    font-size: 0.96rem;
  }

  .topnav a:hover,
  .footer-links a:hover {
    color: var(--text);
  }

  .topbar-actions,
  .hero-actions {
    gap: 0.7rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2.9rem;
    padding: 0.78rem 1.1rem;
    border: 1px solid transparent;
    border-radius: 0.9rem;
    font-weight: 600;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      border-color 180ms ease,
      color 180ms ease,
      box-shadow 180ms ease;
  }

  .btn:hover {
    transform: translateY(-1px);
  }

  .btn-large {
    min-height: 3.4rem;
    padding-inline: 1.35rem;
  }

  .btn-solid {
    background: var(--accent);
    color: #1c1729;
    box-shadow: 0 12px 30px rgba(184, 164, 255, 0.22);
  }

  .btn-solid:hover {
    background: var(--accent-strong);
  }

  .btn-outline {
    border-color: var(--line-strong);
    background: rgba(255, 255, 255, 0.025);
    color: var(--text);
  }

  .btn-outline:hover,
  .btn-quiet:hover {
    border-color: rgba(255, 255, 255, 0.25);
    background: rgba(255, 255, 255, 0.06);
  }

  .btn-quiet {
    border-color: var(--line);
    background: rgba(255, 255, 255, 0.02);
    color: var(--text);
  }

  .hero-grid,
  .intro-layout,
  .comparison-shell,
  .testimonials-layout,
  .footer-grid,
  .cta-card {
    display: grid;
    gap: 2rem;
  }

  .hero-grid {
    grid-template-columns: minmax(0, 1.02fr) minmax(0, 0.98fr);
    align-items: center;
    gap: 3rem;
    padding: 3rem 0 2rem;
  }

  .hero-copy h1 {
    max-width: 10.8ch;
    margin-top: 1.2rem;
    font-size: clamp(3.2rem, 7vw, 5.8rem);
    line-height: 0.94;
    letter-spacing: -0.065em;
  }

  .hero-lead {
    max-width: 38rem;
    margin-top: 1.35rem;
    color: var(--muted);
    font-size: clamp(1.04rem, 1.5vw, 1.22rem);
  }

  .hero-actions {
    margin-top: 1.8rem;
  }

  .hero-meta {
    flex-wrap: wrap;
    gap: 1.1rem;
    margin-top: 1rem;
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .hero-meta span::before {
    content: '◌';
    margin-right: 0.45rem;
    color: var(--accent);
  }

  .hero-visual {
    position: relative;
  }

  .dashboard-card {
    position: relative;
    padding: 1.35rem 1.35rem 0;
    border: 1px solid var(--line);
    border-radius: var(--radius-xl);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.04), rgba(255, 255, 255, 0.015)),
      rgba(17, 21, 18, 0.7);
    box-shadow: var(--shadow-lg);
    overflow: hidden;
    isolation: isolate;
  }

  .dashboard-card::before {
    content: '';
    position: absolute;
    inset: -20% 25% auto;
    height: 10rem;
    background: radial-gradient(circle, rgba(184, 164, 255, 0.28), transparent 70%);
    filter: blur(24px);
    z-index: -1;
  }

  .floating-tag {
    position: absolute;
    z-index: 2;
    padding: 0.52rem 0.76rem;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    background: rgba(17, 20, 17, 0.82);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 0.73rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    backdrop-filter: blur(8px);
  }

  .floating-tag-left {
    top: -0.55rem;
    left: -1rem;
    transform: rotate(-7deg);
  }

  .floating-tag-right {
    top: 3rem;
    right: -1.2rem;
    transform: rotate(8deg);
  }

  .dash-window {
    border: 1px solid var(--line-strong);
    border-radius: 1.6rem;
    background: linear-gradient(180deg, rgba(40, 47, 41, 0.94), rgba(22, 27, 23, 0.96));
    overflow: hidden;
  }

  .dash-chrome,
  .dash-summary,
  .dash-panels,
  .panel-row,
  .proof-person,
  .mosaic-row,
  .compare-pill,
  .comparison-head,
  .comparison-row,
  .testimonial-person {
    display: flex;
    align-items: center;
  }

  .dash-chrome {
    justify-content: space-between;
    gap: 0.75rem;
    padding: 0.9rem 1rem;
    border-bottom: 1px solid var(--line);
    color: var(--muted-soft);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .dash-dots {
    display: inline-flex;
    gap: 0.35rem;
  }

  .dash-dots span {
    width: 0.58rem;
    height: 0.58rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.28);
  }

  .dash-path {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .dash-body {
    padding: 1rem;
  }

  .dash-summary {
    justify-content: space-between;
    gap: 0.8rem;
    padding-bottom: 1rem;
  }

  .dash-summary strong {
    display: block;
    margin-top: 0.1rem;
    font-size: 1.7rem;
    letter-spacing: -0.05em;
  }

  .mini-label {
    color: var(--muted-soft);
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .dash-chart {
    position: relative;
    height: 16rem;
    margin-bottom: 1rem;
    border: 1px solid var(--line);
    border-radius: 1.35rem;
    background: linear-gradient(180deg, rgba(14, 17, 14, 0.7), rgba(20, 24, 20, 0.95));
    overflow: hidden;
  }

  .chart-grid,
  .chart-area {
    position: absolute;
    inset: 0;
  }

  .chart-grid {
    background-image:
      linear-gradient(rgba(255, 255, 255, 0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 100% 25%, 12.5% 100%;
  }

  .chart-area {
    bottom: 0;
    top: auto;
    height: 100%;
  }

  .chart-area-back {
    background: rgba(110, 101, 148, 0.36);
    clip-path: polygon(0 56%, 13% 71%, 28% 69%, 41% 43%, 62% 49%, 78% 57%, 100% 72%, 100% 100%, 0 100%);
  }

  .chart-area-front {
    background: linear-gradient(180deg, rgba(189, 173, 255, 0.55), rgba(189, 173, 255, 0.18));
    clip-path: polygon(0 68%, 13% 78%, 28% 77%, 45% 63%, 62% 65%, 81% 73%, 100% 82%, 100% 100%, 0 100%);
  }

  .dash-panels {
    gap: 1rem;
  }

  .dash-panel,
  .proof-card,
  .feature-card,
  .mosaic-card,
  .steps-card,
  .step-card,
  .testimonial-card,
  .cta-card {
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.03);
  }

  .dash-panel {
    flex: 1;
    min-width: 0;
    padding: 0.95rem 1rem;
    border-radius: 1.25rem;
  }

  .panel-title {
    margin-bottom: 0.7rem;
    color: var(--muted-soft);
    font-family: var(--font-mono);
    font-size: 0.71rem;
    text-transform: uppercase;
  }

  .panel-row {
    justify-content: space-between;
    gap: 0.8rem;
    padding: 0.55rem 0.6rem;
    border-radius: 0.8rem;
    color: var(--muted);
    font-size: 0.93rem;
  }

  .panel-row-active {
    background: var(--accent-deep);
    color: var(--text);
  }

  .proof-card {
    display: grid;
    gap: 1rem;
    width: min(22rem, 86%);
    margin: 1.1rem 0 0 auto;
    padding: 1rem 1.1rem 1.15rem;
    border-radius: 1.25rem 1.25rem 0 0;
    box-shadow: var(--shadow-md);
  }

  .proof-card p,
  .feature-card p,
  .story-list,
  .compare-bar + p,
  .step-card p,
  .testimonial-person span,
  .footer-brand p,
  .cta-card p {
    color: var(--muted);
  }

  .proof-person {
    gap: 0.75rem;
  }

  .proof-avatar {
    display: grid;
    place-items: center;
    width: 2.35rem;
    height: 2.35rem;
    border-radius: 999px;
    background: linear-gradient(135deg, #f2f4ed, #b8a4ff);
    color: #191c18;
    font-weight: 700;
    font-size: 0.83rem;
  }

  .proof-person strong,
  .testimonial-person strong {
    display: block;
  }

  .proof-person span,
  .testimonial-person span {
    font-size: 0.92rem;
  }

  .trust-rail {
    display: grid;
    gap: 1rem;
    margin-top: 1.4rem;
    padding: 1.2rem 0 0;
  }

  .trust-rail p {
    color: var(--muted-soft);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
  }

  .trust-logos {
    flex-wrap: wrap;
    gap: 1.2rem 2rem;
    color: rgba(242, 244, 237, 0.65);
    font-size: clamp(1rem, 1.7vw, 1.35rem);
    font-weight: 650;
    letter-spacing: -0.04em;
  }

  .feature-intro,
  .story-section,
  .comparison-section,
  .steps-section,
  .testimonials-section,
  .cta-section {
    padding: 2.5rem 0 0;
  }

  .intro-layout,
